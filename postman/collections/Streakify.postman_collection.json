  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function isoDate(daysFromToday) {",
          "  const date = new Date();",
          "  date.setDate(date.getDate() + daysFromToday);",
          "  return date.toISOString().slice(0, 10);",
          "}",
          "",
          "pm.collectionVariables.set('fourDaysAgo', isoDate(-4));",
          "pm.collectionVariables.set('threeDaysAgo', isoDate(-3));",
          "pm.collectionVariables.set('yesterday', isoDate(-1));",
          "pm.collectionVariables.set('today', isoDate(0));",
          "pm.collectionVariables.set('tomorrow', isoDate(1));"
        ]
      }
    }
